{
	"name": "@os-eco/trellis-cli",
	"version": "0.2.0",
	"description": "Git-native specs, plans, and handoff artifacts for the os-eco toolchain",
	"author": "Jaymin West",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/RogerNavelsaker/trellis.git"
	},
	"homepage": "https://github.com/RogerNavelsaker/trellis#readme",
	"bugs": {
		"url": "https://github.com/RogerNavelsaker/trellis/issues"
	},
	"keywords": [
		"os-eco",
		"trellis",
		"cli",
		"git-native",
		"workflow",
		"planning"
	],
	"files": [
		"src",
		"docs",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"main": "src/index.ts",
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"trellis": "src/index.ts",
		"tl": "src/index.ts"
	},
	"scripts": {
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"version:bump": "bun run scripts/version-bump.ts"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"typescript": "^5.9.0"
	},
	"engines": {
		"bun": ">=1.0.0"
	}
}
